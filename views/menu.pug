extends layout

block content
  section.page-intro
    .container
      h1.section-title Our Menu
      p
        | Explore donut favorites, fresh coffee, and cozy café staples.
      p
        | Take a look at some of our most popular offerings, from classic donuts
        | to fresh coffee and seasonal specialties.

  section.menu-preview
    .container
      .menu-grid
        article.menu-card
          h2 Classic Donuts
          p Glazed, chocolate, sprinkled, and other everyday favorites made fresh daily.

        article.menu-card
          h2 Specialty Coffee
          p Fresh brewed coffee, espresso drinks, and warm café staples for busy mornings.

        article.menu-card
          h2 Seasonal Specials
          p Rotating flavors and limited-time treats that give the menu variety year-round.

      .menu-actions
        a.button(href='https://www.doordash.com/', target='_blank', rel='noopener noreferrer') Order with DoorDash
        a.button(href='https://www.ubereats.com/', target='_blank', rel='noopener noreferrer') Order with Uber Eats