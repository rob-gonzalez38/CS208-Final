extends layout

block content
  section.hero
    .container.hero-content
      p.hero-kicker Fresh donuts, hot coffee, downtown comfort
      h1.hero-title Welcome to 
        span.brand-script Downtown Donuts
      p.hero-text
        | Serving the community since 1992 with cozy mornings, classic favorites,
        | and a modern downtown feel.
      .hero-actions
        a.button(href='/menu') View Menu
        a.button.button-secondary(href='https://www.doordash.com/', target='_blank', rel='noopener noreferrer') Order Online

  //Quick highlights for the homepage
  section.home-highlights
    .container
      h2.section-title Why locals love us
      .highlights-grid
        article.highlight-card
          h3 Made fresh daily
          p Classic donuts, coffee, and familiar favorites prepared fresh each day.
 
        article.highlight-card
          h3 Family-owned since 1992
          p A neighborhood staple built on warmth, tradition, and friendly service.

        article.highlight-card
          h3 Easy online ordering
          p Grab breakfast on the go with convenient delivery and pickup options.
