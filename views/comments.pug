extends layout

block content
  section.page-intro
    .container
      h1.section-title Customer Comments
      p
        | Read what customers are saying and share your own experience.

  section.comments-preview
    .container
      .comments-layout
        article.comment-form-card
          h2 Leave a comment

            if errorMessage
              p.form-error= errorMessage

          form(method='POST', action='/comments')
            .form-group
              label(for='name') Name
              input(type='text', id='name', name='name', 
                    placeholder='Your name', value=formData ? formData.name : '')

            .form-group
              label(for='comment') Comment
              textarea(id='comment', name='comment', rows='5', 
                      placeholder='Share your experience')= formData ? formData.comment : ''

            button.button(type='submit') Submit Comment

        article.comment-list-card
          h2 Recent comments

          if comments && comments.length
            each comment in comments
              article.comment-item
                h3= comment.name
                p= comment.comment
                small= comment.created_at

          else 
            p No comments yet. Be the first to share your experience.
            

         if totalPages && totalPages > 1
            nav.pagination(aria-label='Comment pagination')
              if currentPage > 1
                a(href=`/comments?page=${currentPage - 1}`) Previous

              span Page #{currentPage} of #{totalPages}

              if currentPage < totalPages
                a(href=`/comments?page=${currentPage + 1}`) Next 