extends layout

block content
  section.page-intro
    .container
      h1.section-title About Us
      p
        | Downtown Donuts is a family-owned shop that has served the downtown community
        | since 1992.

  section.about-story
    .container
      .about-grid
        article.about-card
          h2 Built on tradition
          p
            | This prototype emphasizes warmth, consistency, and the cozy neighborhood
            | identity described in the client brief.

        article.about-card
          h2 A modern local favorite
          p
            | While the business has deep roots, the site design aims to feel modern,
            | minimal, and easy to use on mobile devices.

        article.about-card
          h2 Made for connection
          p
            | The final site will help customers explore the menu, order online, and
            | share comments about their experience.